EMAIL_FROM=PractitionerApp <noreply@practitionerapp.com>

# Reminders — protect /api/reminders/send from unauthorized calls
# Generate with: openssl rand -hex 32
CRON_SECRET=

# AI (Anthropic Claude)
ANTHROPIC_API_KEY=
